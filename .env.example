DJANGO_ENV=local
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-secret-key-change-in-prod-please-1234567890
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

POSTGRES_DB=pettrace
POSTGRES_USER=pettrace
POSTGRES_PASSWORD=pettrace
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://pettrace:pettrace@postgres:5432/pettrace

REDIS_URL=redis://redis:6379/0
REPORTS_CACHE_TTL=120
REPORTS_WARMUP_ENABLED=1
REPORTS_WARMUP_DAYS=1,7,30
REPORTS_WARMUP_INTERVAL_SECONDS=900
CRM_DISPATCH_INTERVAL_SECONDS=120
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

SUPERUSER_EMAIL=admin@pettrace.local
SUPERUSER_PASSWORD=admin123

POSTGRES_PORT_BIND=5432:5432
REDIS_PORT_BIND=6379:6379
WEB_PORT_BIND=8000:8000
FLOWER_PORT_BIND=5555:5555
NGINX_PORT_BIND=80:80
PGADMIN_PORT_BIND=5050:80

PGADMIN_DEFAULT_EMAIL=pgadmin@pettrace.dev
PGADMIN_DEFAULT_PASSWORD=change-me-please
